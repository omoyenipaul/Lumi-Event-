    <!--FAQ SECTION-->
    <section id="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item reveal">
          <button class="faq-question">
            <h3>How do I book your services?</h3>
            <span class="faq-icon">+</span>
