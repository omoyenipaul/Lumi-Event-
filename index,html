                <p>Open Daily — Closes 12am</p>
              </div>
            </div>
          </div>

          <a
            href="https://wa.me/2348161640477"
            class="btn whatsapp-btn"
            target="_blank"
          >
            💬 Chat on WhatsApp
          </a>
        </div>

        <!-- RIGHT SIDE — FORM -->
        <div class="contact-form reveal-right
          <h3>Send Us a Message</h3>
          <form
            id="contact-form"
            action="https://formspree.io/f/YOUR_ID"
            method="POST"
          >
            <div class="form-row">
              <div class="form-group">
                <label>Your Name</label>
                <input
                  type="text"
                  name="name"
                  placeholder="e.g. Amaka Obi"
                  required
                />
              </div>
              <div class="form-group">
                <label>Phone Number</label>
                <input
                  type="tel"
                  name="phone"
                  placeholder="e.g. 0801 234 5678"
                  required
                />
              </div>
            </div>

            <div class="form-group">
              <label>Email Address</label>
              <input
                type="email"
                name="email"
                placeholder="your@email.com"
                required
              />
            </div>

            <div class="form-group">
              <label>Type of Event</label>
              <select name="event_type" required>
                <option value="" disabled selected>Select event type</option>
                <option>Wedding</option>
                <option>Birthday Party</option>
                <option>Corporate Event</option>
                <option>Naming Ceremony</option>
                <option>Burial Ceremony</option>
                <option>Other</option>
              </select>
            </div>

            <div class="form-group">
              <label>Tell Us About Your Event</label>
              <textarea
                name="message"
                placeholder="Event date, number of guests, services needed..."
              >
              </textarea>
            </div>

            <button type="submit" class="btn">Send Message</button>
          </form>
        </div>
      </div>
    </section>

